pipeline {
    agent any

    tools {
        nodejs "NodeJS"   // Make sure NodeJS tool is configured in Jenkins
    }

    stages {

        stage('Clone') {
            steps {
                git 'https://github.com/yourusername/shoppro.git'
            }
        }

        stage('Install Dependencies') {
            steps {
                sh 'npm install'
            }
        }

        stage('Test') {
            steps {
                sh 'npm test || true'
            }
        }

        stage('Deploy') {
            steps {
                sh 'nohup npm start > app.log 2>&1 &'
            }
        }
    }
}
